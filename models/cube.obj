# Simple cube OBJ file
# 8 vertices, 6 faces (quads -> triangulated by loader)

v -1.0 -1.0  1.0
v  1.0 -1.0  1.0
v  1.0  1.0  1.0
v -1.0  1.0  1.0
v -1.0 -1.0 -1.0
v  1.0 -1.0 -1.0
v  1.0  1.0 -1.0
v -1.0  1.0 -1.0

vt 0.0 0.0
vt 1.0 0.0
vt 1.0 1.0
vt 0.0 1.0

vn  0.0  0.0  1.0
vn  0.0  0.0 -1.0
vn  0.0  1.0  0.0
vn  0.0 -1.0  0.0
vn  1.0  0.0  0.0
vn -1.0  0.0  0.0

# Front
f 1/1/1 2/2/1 3/3/1 4/4/1
# Back
f 6/1/2 5/2/2 8/3/2 7/4/2
# Top
f 4/1/3 3/2/3 7/3/3 8/4/3
# Bottom
f 5/1/4 6/2/4 2/3/4 1/4/4
# Right
f 2/1/5 6/2/5 7/3/5 3/4/5
# Left
f 5/1/6 1/2/6 4/3/6 8/4/6
